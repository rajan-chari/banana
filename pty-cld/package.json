{
  "name": "pty-cld",
  "version": "0.2.1",
  "description": "PTY wrapper for Claude Code with emcom message notifications",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pty-cld": "dist/index.js"
  },
  "files": [
    "dist/",
    "bin/"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",

    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@xterm/headless": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
