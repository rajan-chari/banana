{
  "name": "pty-cld",
  "version": "0.2.0",
  "description": "PTY wrapper for Claude Code with emcom message notifications",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pty-cld": "dist/index.js"
  },
  "files": [
    "dist/",
    "bin/",
    "public/"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "serve": "node dist/index.js --serve",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@xterm/headless": "^6.0.0",
    "express": "^4.21.0",
    "node-pty": "^1.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
