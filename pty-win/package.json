{
  "name": "pty-win",
  "version": "0.1.35",
  "description": "Browser-based terminal multiplexer with emcom integration",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pty-win": "dist/index.js"
  },
  "files": [
    "dist/",
    "public/"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check:public": "tsc -p tsconfig.public.json",
    "check:test": "tsc -p tsconfig.test.json",
    "check:deps": "madge --circular public/ && madge --circular --extensions ts src/",
    "check": "npm run build -- --noEmit && npm run check:public && npm run check:test && npm run check:deps"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "express": "^4.21.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "happy-dom": "^20.9.0",
    "madge": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
